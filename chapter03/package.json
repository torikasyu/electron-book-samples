{
  "name": "electron-react-typescript-sample",
  "version": "1.0.0",
  "description": "Electron + React + TypeScriptのサンプルアプリケーション",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "npm-run-all -p dev:*",
    "dev:webpack": "webpack --config webpack.config.js --watch",
    "dev:electron": "wait-on dist/main.js dist/index.html && electron .",
    "build": "webpack --config webpack.config.js --mode production",
    "lint": "eslint --ext .ts,.tsx src/",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "keywords": [
    "electron",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^22.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "@typescript-eslint/eslint-plugin": "^5.48.0",
    "@typescript-eslint/parser": "^5.48.0",
    "css-loader": "^6.7.3",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^8.31.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-react": "^7.31.11",
    "html-webpack-plugin": "^5.5.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.1",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.4.2",
    "typescript": "^4.9.4",
    "wait-on": "^7.0.1",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1"
  }
}